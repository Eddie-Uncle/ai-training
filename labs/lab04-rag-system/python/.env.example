# Required: Anthropic API key — used for answer generation and LLM-as-judge evaluation
ANTHROPIC_API_KEY=your-anthropic-key-here

# Required: Voyage AI API key — used for code embeddings (model: voyage-code-2)
# Get yours at https://dash.voyageai.com
VOYAGE_API_KEY=your-voyage-key-here

# Optional: LLM provider (only "anthropic" is supported in this build)
LLM_PROVIDER=anthropic

# Optional: Override the Anthropic model (default: claude-3-haiku-20240307)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
